# Only project metadata and `src` are needed to build the application, deployment,
# evaluation, and service images. Keep the context small and its cache stable.
.git
archive
.hypothesis
.mypy_cache
.benchmarks
.lote
.github
.venv
.chefe
tests
# `docs` builds the landing page and documentation image, so its source has to reach the context.
# Its installed packages and previous output must not, since the image installs and builds its own.
docs/node_modules
docs/dist
docs/.astro
docs/src/content/docs/**/*.bak
__pycache__
*.pyc
.pytest_cache
.ruff_cache
.pyrefly
site
backups
*.dump
.env
.mcp.json
htmlcov
.coverage
src/web/node_modules
src/web/build
src/web/.svelte-kit
