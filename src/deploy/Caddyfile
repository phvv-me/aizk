:8081 {
	encode zstd gzip

	@mcp path /mcp /mcp/* /.well-known/oauth-authorization-server /.well-known/oauth-protected-resource/mcp /authorize /token /register /auth/callback /consent
	handle @mcp {
		reverse_proxy server:8080
	}

	@upload {
		method PUT
		path /api/uploads/*
	}
	handle @upload {
		reverse_proxy api:8010
	}

	@api path /api /api/*
	handle @api {
		respond 404
	}

	header {
		Referrer-Policy same-origin
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}

	# SvelteKit owns a closed set of paths: the signed-in application, the browser sign-in flow
	# that is not the MCP server's own callback above, its event stream, and its build assets.
	# Everything else, including every documentation page ever added, is the static site, so a
	# new docs page never needs a routing change here.
	@app path /app /app/* /auth/* /events/* /_app/*
	handle @app {
		reverse_proxy frontend:3000
	}

	handle {
		reverse_proxy docs:8082
	}
}
