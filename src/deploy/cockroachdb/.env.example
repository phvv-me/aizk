OPENROUTER_API_KEY=
AIZK_COCKROACH_SQL_PORT=26258
AIZK_COCKROACH_HTTP_PORT=8181
AIZK_COCKROACH_MCP_PORT=8088

# Managed CockroachDB can build both URLs from the fields below. Complete SQLAlchemy URLs remain
# available when copying generated connection strings. Keep sslmode=verify-full and let local
# clients use the downloaded sslrootcert path.
# AIZK_DATABASE_BACKEND=cockroachdb
# AIZK_DB_HOST=CLUSTER
# AIZK_DB_PORT=26257
# AIZK_DB_NAME=aizk
# AIZK_ADMIN_USER=aizk
# AIZK_ADMIN_PASSWORD=
# AIZK_APP_USER=aizk_app
# AIZK_APP_PASSWORD=
# AIZK_DB_SSL_MODE=verify-full
# AIZK_DB_SSL_ROOT_CERTIFICATE_PATH=/home/USER/.postgresql/root.crt
# AIZK_DATABASE_URL=cockroachdb+asyncpg://aizk_app:REPLACE@CLUSTER:26257/aizk?sslmode=verify-full&sslrootcert=/home/USER/.postgresql/root.crt
# AIZK_ADMIN_DATABASE_URL=cockroachdb+asyncpg://aizk:REPLACE@CLUSTER:26257/aizk?sslmode=verify-full&sslrootcert=/home/USER/.postgresql/root.crt
