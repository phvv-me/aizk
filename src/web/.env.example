# Same AIZK_* names the Python settings use; values live in the deployment env.
AIZK_LOGTO_URL=https://auth.phvv.me
AIZK_WEB_CLIENT_ID=
AIZK_WEB_CLIENT_SECRET=
AIZK_WEB_PUBLIC_URL=https://aizk.phvv.me
AIZK_WEB_SESSION_SECRET=
