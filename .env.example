# aizk serving and provider configuration. Copy to .env and edit; docker compose auto-loads .env
# for the vLLM container knobs, and the AIZK_-prefixed vars feed the aizk app through pydantic
# settings. Leave a key line commented to keep its default rather than blanking it to empty.

# vLLM embedder container (vllm-emb), FP8 on the Ada 4090 so it co-resides with the reranker.
EMBED_MODEL=Qwen/Qwen3-VL-Embedding-2B
EMBED_QUANTIZATION=fp8
EMBED_MAX_MODEL_LEN=8192
EMBED_GPU_MEM_UTIL=0.4
EMBED_PORT=8000

# vLLM reranker container (vllm-rerank), FP8, its own port so embed + rerank share the one GPU.
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_QUANTIZATION=fp8
RERANK_MAX_MODEL_LEN=8192
RERANK_GPU_MEM_UTIL=0.4
RERANK_PORT=8001

# aizk app: which served lanes to dial. The api backends reach the two vLLM containers above.
AIZK_EMBED_BACKEND=api
AIZK_EMBED_URL=http://localhost:8000/v1
AIZK_EMBED_MODEL=qwen3-vl-emb
AIZK_RERANK_BACKEND=api
AIZK_RERANK_URL=http://localhost:8001/v1
AIZK_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# LLM provider. Everything is OpenAI-compatible, so selecting a provider is just pointing the url
# and key at it. The default is the local vLLM; Cerebras is one selectable hosted provider.
AIZK_LLM_PROVIDER=vllm
AIZK_LLM_URL=http://localhost:8000/v1
AIZK_LLM_MODEL=qwen2.5:7b
# AIZK_LLM_API_KEY defaults to the ambient OPENAI_API_KEY when left unset, so an existing key
# carries over. Set it explicitly to switch providers.
# AIZK_LLM_API_KEY=

# Cerebras (https://api.cerebras.ai/v1) as a selectable provider. Uncomment these and drop the
# CEREBRAS_API_KEY placeholder in to route extraction through it.
# AIZK_LLM_PROVIDER=cerebras
# AIZK_LLM_URL=https://api.cerebras.ai/v1
# AIZK_LLM_MODEL=llama-3.3-70b
# AIZK_LLM_API_KEY=${CEREBRAS_API_KEY}
# CEREBRAS_API_KEY=
