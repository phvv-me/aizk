---
// A server-rendered SVG flow diagram. No client JS, so it is visible in every browser including
// Safari, which the @xyflow/svelte canvas was not. Nodes sit on an integer col/row grid, edges
// are straight lines clipped to each box with an arrowhead, and a node with an href becomes a
// link. Everything is drawn with currentColor, so it follows the page theme in light and dark.
//
// Author a diagram like this:
//   <Diagram
//     title="How a write becomes memory"
//     nodes={[
//       { id: 'a', label: 'agent', col: 0, row: 0 },
//       { id: 'w', label: 'write path', col: 1, row: 0, href: '/docs/dev/write/intake/' },
//     ]}
//     edges={[{ from: 'a', to: 'w', label: 'remember' }]}
//   />

interface Node {
  id: string;
  label: string;
  col: number;
  row: number;
  href?: string;
  emphasis?: boolean;
}
interface Edge {
  from: string;
  to: string;
  label?: string;
  dashed?: boolean;
}
interface Props {
  title: string;
  nodes: Node[];
  edges: Edge[];
  colGap?: number;
  rowGap?: number;
}

const { title, nodes, edges, colGap = 210, rowGap = 104 } = Astro.props;

const H = 46;
const CHAR = 8.2;
const PAD_X = 30;
const width = (label: string) => Math.min(320, Math.max(96, Math.round(label.length * CHAR + PAD_X)));

const placed = new Map(
  nodes.map((n) => {
    const w = width(n.label);
    const cx = n.col * colGap;
    const cy = n.row * rowGap;
    return [n.id, { ...n, w, h: H, cx, cy, x: cx - w / 2, y: cy - H / 2, hw: w / 2, hh: H / 2 }];
  }),
);

// Where the straight line from one box center to another leaves the first box.
function exit(from: { cx: number; cy: number; hw: number; hh: number }, to: { cx: number; cy: number }) {
  const dx = to.cx - from.cx;
  const dy = to.cy - from.cy;
  const scale = Math.min(from.hw / (Math.abs(dx) || 1e-6), from.hh / (Math.abs(dy) || 1e-6));
  return { x: from.cx + dx * scale, y: from.cy + dy * scale };
}

const drawn = edges.flatMap((e) => {
  const a = placed.get(e.from);
  const b = placed.get(e.to);
  if (!a || !b) return [];
  const start = exit(a, b);
  const end = exit(b, a);
  return [{ ...e, x1: start.x, y1: start.y, x2: end.x, y2: end.y, mx: (start.x + end.x) / 2, my: (start.y + end.y) / 2 }];
});

const boxes = [...placed.values()];
const minX = Math.min(...boxes.map((b) => b.x));
const maxX = Math.max(...boxes.map((b) => b.x + b.w));
const minY = Math.min(...boxes.map((b) => b.y));
const maxY = Math.max(...boxes.map((b) => b.y + b.h));
const M = 16;
const vb = `${minX - M} ${minY - M} ${maxX - minX + 2 * M} ${maxY - minY + 2 * M}`;
const uid = `d${Math.abs([...title].reduce((h, c) => (h * 31 + c.charCodeAt(0)) | 0, 7))}`;
---

<figure class="aizk-diagram not-content">
  <svg viewBox={vb} role="img" aria-label={title} preserveAspectRatio="xMidYMid meet">
    <title>{title}</title>
    <defs>
      <marker id={`${uid}-arrow`} viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="currentColor"></path>
      </marker>
    </defs>

    {
      drawn.map((e) => (
        <g class="edge">
          <line
            x1={e.x1}
            y1={e.y1}
            x2={e.x2}
            y2={e.y2}
            stroke="currentColor"
            stroke-width="1.4"
            stroke-dasharray={e.dashed ? '5 4' : undefined}
            marker-end={`url(#${uid}-arrow)`}
          />
          {e.label && (
            <>
              <rect
                x={e.mx - (e.label.length * 5.6) / 2 - 4}
                y={e.my - 9}
                width={e.label.length * 5.6 + 8}
                height={16}
                rx="2"
                class="edge-label-bg"
              />
              <text x={e.mx} y={e.my + 3} text-anchor="middle" class="edge-label">
                {e.label}
              </text>
            </>
          )}
        </g>
      ))
    }

    {
      boxes.map((b) => {
        const box = (
          <g class={`node${b.emphasis ? ' emphasis' : ''}${b.href ? ' link' : ''}`}>
            <rect x={b.x} y={b.y} width={b.w} height={b.h} rx="2"></rect>
            <text x={b.cx} y={b.cy + 4} text-anchor="middle">
              {b.label}
            </text>
          </g>
        );
        return b.href ? <a href={b.href}>{box}</a> : box;
      })
    }
  </svg>
</figure>

<style>
  .aizk-diagram {
    margin: 1.5rem auto;
    max-width: 46rem;
  }
  .aizk-diagram svg {
    width: 100%;
    height: auto;
    color: var(--sl-color-gray-1, currentColor);
    overflow: visible;
  }
  .edge {
    color: var(--sl-color-gray-3, currentColor);
  }
  .edge-label {
    font-size: 11px;
    fill: var(--sl-color-gray-2, currentColor);
    font-family: var(--sl-font-mono, monospace);
  }
  .edge-label-bg {
    fill: var(--sl-color-bg, #fff);
    stroke: none;
  }
  .node rect {
    fill: var(--sl-color-bg, transparent);
    stroke: currentColor;
    stroke-width: 1.3;
  }
  .node text {
    font-size: 13px;
    fill: currentColor;
    font-family: var(--sl-font, sans-serif);
  }
  .node.emphasis rect {
    fill: var(--sl-color-gray-6, rgba(128, 128, 128, 0.12));
    stroke-width: 2;
  }
  .aizk-diagram a {
    text-decoration: none;
  }
  .node.link {
    cursor: pointer;
  }
  .node.link rect {
    transition: fill 0.12s ease;
  }
  .aizk-diagram a:hover .node.link rect,
  .aizk-diagram a:focus-visible .node.link rect {
    fill: var(--sl-color-gray-5, rgba(128, 128, 128, 0.18));
  }
  /* On the marketing landing page the Starlight vars are absent, so fall back to the daisyUI
     base tokens for the label background and the node fill. */
  [data-aizk-marketing] .edge-label-bg {
    fill: var(--color-base-100, #fff);
  }
  [data-aizk-marketing] .node rect {
    fill: var(--color-base-100, transparent);
  }
</style>
