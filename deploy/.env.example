# aizk configuration, the single source for every docker-compose knob, initdb/roles.sh password,
# and config/settings.py default this stack has. Copy to .env and edit; docker compose auto-loads
# .env from this directory for every ${VAR:-default} interpolation below, the db service also gets
# it passed through as real container env (env_file) so initdb/roles.sh can read it, and
# pydantic-settings loads the same file into Settings (env_prefix="AIZK_", env_file=<this file>).
# One naming scheme covers both readers: every var here is AIZK_-prefixed, and the ones Settings
# also reads share its exact field name uppercased, so one edit moves both. A value the process
# environment already exports still wins over whatever this file says (init kwarg > env var >
# .env > field default is pydantic-settings' own precedence), so a `.env`-free host or a CI runner
# setting AIZK_DATABASE_URL directly is unaffected by any of this. Leave a line commented to keep
# its field's own default rather than blanking it to empty; every ${VAR:-default} in
# docker-compose.yml and every Settings field default already agrees with what is written here.

# Postgres (compose `db` service). POSTGRES_USER stays the fixed "aizk_admin" role name in
# docker-compose.yml itself, not a var here, see its comment for why.
AIZK_DB_NAME=aizk
AIZK_DB_PORT=5433
AIZK_ADMIN_PASSWORD=aizk
AIZK_APP_PASSWORD=aizk_app
# app-role connection pool: a real pool by default (db_pool_size steady, db_pool_max_overflow
# above it under burst), NullPool only for the pytest suite's many per-test event loops.
#AIZK_DB_POOL_SIZE=10
#AIZK_DB_POOL_MAX_OVERFLOW=10
#AIZK_DB_NULL_POOL=false

# The `server` compose service is the whole engine, the MCP server plus the worker (which runs the
# scheduled maintenance passes and the auto-backup) in one container. It sets its own
# container-internal db/model hosts, HTTP transport, and backup enable inline in docker-compose.yml,
# so nothing here is needed for it. This is only the host port the MCP server is published on.
#AIZK_MCP_PUBLISH_PORT=8080

# Public identity. Logto is the source of truth for subjects, organizations, memberships, roles,
# permissions, and the `customData.public` organization flag. Aizk derives OIDC discovery, issuer,
# JWKS, signing algorithms, and Management API endpoints from the one Logto URL. It derives the
# token audience by adding `/mcp` to the public Aizk URL. Leave this section commented for the
# local auth-off stack.
#AIZK_LOGTO_ENDPOINT=https://auth.example.com
#AIZK_LOGTO_ADMIN_ENDPOINT=https://admin-auth.example.com
#AIZK_LOGTO_URL=https://auth.example.com
#AIZK_MCP_PUBLIC_URL=https://aizk.example.com
#AIZK_LOGTO_REQUIRED_SCOPES=["control"]
#AIZK_LOGTO_WRITABLE_ROLES=["admin","editor"]

# Memberships, roles, and public organizations are resolved from Logto rather than copied into
# aizk. Create a Logto M2M application with a role carrying the Management API `all` permission
# and place its credentials only in the host environment. The OSS Management API resource has
# this fixed identifier.
#AIZK_LOGTO_CLIENT_ID=
#AIZK_LOGTO_CLIENT_SECRET=
#AIZK_LOGTO_MANAGEMENT_RESOURCE=https://default.logto.app/api
#AIZK_LOGTO_CACHE_SECONDS=60
#AIZK_LOGTO_HTTP_TIMEOUT=10

# `aizk backup`/`aizk restore` run pg_dump/pg_restore, which must be at least the server's version.
# The server image ships the pg18 client, so inside compose the tools run there against db:5432 with
# these left unset. Only when running the CLI from a host with an older client, point the launcher
# at the db container and its internal 5432. See docs/operations.md.
#AIZK_PG_CLIENT_LAUNCHER=["docker","exec","-i","aizk-db-1"]
#AIZK_BACKUP_DATABASE_URL=postgresql://aizk_admin:aizk@localhost:5432/aizk

# vLLM embedder container (vllm-emb), FP8 on Ada hardware.
# A 2026-07-12 shootout on 1,903 real vault chunks and 1,101 title queries measured this
# default against the text-only Qwen3-Embedding family at the schema's 1024 dimensions:
# VL-2B hit@5 88.0% / MRR 0.794, text-0.6B 89.3% / 0.792, text-4B 90.1% / 0.802. The text
# models buy 1-2 points of retrieval and a wider off-corpus distance gap (0.63 vs 0.46
# minimum, cleaner floor separation) at the price of the image lane, which only the VL
# checkpoint embeds into the shared space. Native dimensions added under a point, so the
# 1024 Matryoshka cut stays. Swap AIZK_EMBED_CHECKPOINT to Qwen/Qwen3-Embedding-4B for a
# text-only deployment and re-run `aizk graph reembed`.
# AIZK_EMBED_CHECKPOINT is the HF weights vLLM loads; AIZK_EMBED_MODEL is the short served alias
# clients dial, and must match the identically named Settings field below.
AIZK_EMBED_CHECKPOINT=Qwen/Qwen3-VL-Embedding-2B
AIZK_EMBED_QUANTIZATION=fp8
# aizk chunks are 2048 chars (<=700 tokens), so 2048 is ample and frees ~10x the KV the old 8192
# reserved; max-num-seqs sets the pooling batch width that a prefill-only lane saturates on.
AIZK_EMBED_MAX_MODEL_LEN=2048
AIZK_EMBED_MAX_NUM_SEQS=64
AIZK_EMBED_GPU_MEM_UTIL=0.30
AIZK_EMBED_PORT=8000

# vLLM extraction chat container (vllm-llm), default-on and co-resident with the embedder.
# Gemma 4 E2B is the official Google w4a16 QAT
# compressed-tensors checkpoint (Apache 2.0, ungated, day-0 vLLM support, JSON/function-calling
# trained). The larger E4B (google/gemma-4-E4B-it-qat-w4a16-ct) was the first choice but ruled out
# twice over: a ~9.23 GiB process footprint left under 400 MiB of margin against what is
# physically free once the embedder and reranker hold their own share, a gap that survived five
# separate tuning attempts (gpu-memory-utilization 0.35/0.32/0.34, max-num-seqs 48/16/12, with and
# without PYTORCH_CUDA_ALLOC_CONF=expandable_segments); and separately, standalone with the whole
# GPU to itself, E4B could not reliably answer the combined call's strict-mode JSON schema at all
# on this vLLM version (v0.24.0) — every attempt (a trivial one-sentence input included) ran to
# extract_max_tokens with no valid JSON, while the identical call against E2B worked cleanly
# across 3000+ real chunks. E2B's 7.23 GiB footprint fits with room to spare and its structured
# output was fully reliable throughout. Both original objections have since cleared: the rerank
# swap to the 2B VL model freed ~4 GB, so E4B now fits with ~3.4 GiB of margin, and a v0.24.0
# re-check found E4B emitting valid strict-schema JSON 7/7. E2B stays the default only because it
# is ~40% faster; set AIZK_LLM_CHECKPOINT to the E4B repo to spend that speed on extraction quality.
# Qwen3.5-4B was ruled out earlier still: it ships no official GPTQ-Int4 at 4B, and its
# Gated-DeltaNet hybrid architecture added a fixed-size Mamba cache block per concurrent sequence
# that capped real concurrency near 12-13 on this shared card no matter how max-model-len was
# tuned, while Gemma 4's ordinary local/global attention hybrid carries no such extra floor.
# vLLM auto-detects compressed-tensors from the checkpoint; AIZK_LLM_QUANTIZATION is still named
# explicitly, matching how every other service here names its own quantization. max-num-seqs
# matches settings.graph_build_concurrency so this pipeline's own concurrency is what saturates
# vLLM's continuous batching.
AIZK_LLM_CHECKPOINT=google/gemma-4-E2B-it-qat-w4a16-ct
AIZK_LLM_QUANTIZATION=compressed-tensors
AIZK_LLM_MAX_MODEL_LEN=8192
AIZK_LLM_MAX_NUM_SEQS=48
AIZK_LLM_KV_CACHE_DTYPE=fp8
AIZK_LLM_GPU_MEM_UTIL=0.55
AIZK_LLM_PORT=8002

# The cross-encoder rerank lane, vLLM serving the original Qwen3 reranker checkpoint as a
# sequence classifier over /v1/rerank. The 4B is the measured floor: correctly templated on
# 253 real vault queries reranking the embedder's own top 8, the 0.6B degraded MRR 0.90 to
# 0.77 while the 4B held 0.91, so never economize this lane down to the small checkpoint.
AIZK_RERANK_CHECKPOINT=Qwen/Qwen3-Reranker-4B
AIZK_RERANK_QUANTIZATION=fp8
AIZK_RERANK_MAX_MODEL_LEN=2048
AIZK_RERANK_MAX_NUM_SEQS=32
AIZK_RERANK_GPU_MEM_UTIL=0.20
AIZK_RERANK_PORT=8004

# Aizk dials the model services through these OpenAI-compatible endpoints.
AIZK_EMBED_URL=http://localhost:8000/v1
AIZK_EMBED_MODEL=qwen3-vl-emb
# The model emits 2048 dimensions natively. Aizk stores its supported 1024-d Matryoshka prefix so
# this value must be chosen before the schema is created and changed only with a vector migration.
AIZK_EMBED_DIM=1024
# LLM provider for graph extraction. Everything is OpenAI-compatible, so selecting a provider is
# just pointing the url and key at it. The default is the local vllm-llm container above, always
# running now; point AIZK_LLM_URL at a cloud provider instead to switch off it. The Ollama
# container some hosts still run is no longer read by aizk at all, its own compose service if any
# stays stopped-pointing-at rather than referenced here.
AIZK_LLM_PROVIDER=vllm
AIZK_LLM_URL=http://localhost:8002/v1
AIZK_LLM_MODEL=gemma4-e2b-llm
# Recall reranks its evidence lanes through this endpoint when set; leaving it empty keeps
# recall single-statement with no cross-encoder pass.
AIZK_RERANK_URL=http://localhost:8004/v1
AIZK_RERANK_MODEL=qwen3-reranker
# The gliner sidecar answers gate calls (extraction gating, routing, query mentions) when
# set, keeping torch out of the server process; empty loads GLiNER2 in process instead.
AIZK_GLINER_GATE_URL=http://localhost:8006
AIZK_GLINER_DEVICE=cuda
AIZK_GLINER_PORT=8006
# AIZK_LLM_API_KEY defaults to the ambient OPENAI_API_KEY when left unset, so an existing key
# carries over. Set it explicitly to switch providers.
# AIZK_LLM_API_KEY=
# Gemma 4 answers directly with no thinking preamble unless a <|think|> token is placed in the
# system prompt (the opposite default of Qwen3's hybrid-thinking models), so this stays unset for
# the default model. A future hybrid-thinking model would set it here instead, e.g.
# {"enable_thinking": false}; JSON-decoded into Settings.llm_chat_template_kwargs, empty for any
# other provider so a hosted OpenAI-shaped endpoint never sees an extra_body field it might reject.
#AIZK_LLM_CHAT_TEMPLATE_KWARGS={}

# External benchmark generation and judging. Leaving these unset reuses the extraction endpoint
# and is diagnostic. A reference GroupMemBench report uses GPT-5 for both model names and k=10.
#AIZK_EVAL_URL=https://api.openai.com/v1
#AIZK_EVAL_API_KEY=
#AIZK_EVAL_MODEL=gpt-5
#AIZK_EVAL_JUDGE_MODEL=gpt-5
#AIZK_EVAL_CONCURRENCY=4
#AIZK_EVAL_MAX_TOKENS=512

# Graph build concurrency: pending chunks extracted and consolidated at once, shared by the inline
# force_rebuild path and the pgqueuer worker's extraction entrypoint (and its own concurrency_limit
# on the extraction entrypoint). Matches AIZK_LLM_MAX_NUM_SEQS above so this setting is the true
# bottleneck, never a starved queue on the server side.
#AIZK_GRAPH_BUILD_CONCURRENCY=48
# pgqueuer jobs `aizk worker` dequeues per round; must comfortably exceed
# AIZK_GRAPH_BUILD_CONCURRENCY for the queue path to actually keep enough chunks in flight to
# saturate vLLM's continuous batching, the queue-side half of the concurrency fix.
#AIZK_QUEUE_BATCH_SIZE=64

# GLiNER2 relevance gate: a 205M CPU pre-filter ahead of the combined extraction call, skipping
# the LLM call entirely for a chunk that names none of the ontology's own entity types. The
# gate always runs, so AIZK_GLINER_GATE_URL must point at a live sidecar.
#AIZK_GLINER_GATE_MODEL=fastino/gliner2-base-v1
#AIZK_GLINER_GATE_THRESHOLD=0.7
#AIZK_GLINER_GATE_DEVICE=cpu

# Cerebras (https://api.cerebras.ai/v1) as a selectable provider. Uncomment these and drop the
# CEREBRAS_API_KEY placeholder in to route extraction through it.
# AIZK_LLM_PROVIDER=cerebras
# AIZK_LLM_URL=https://api.cerebras.ai/v1
# AIZK_LLM_MODEL=llama-3.3-70b
# AIZK_LLM_API_KEY=${CEREBRAS_API_KEY}
# CEREBRAS_API_KEY=
